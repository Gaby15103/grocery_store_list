        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="org.gaby15103.grocery_master"
            android:targetClass="org.gaby15103.grocery_master.MainActivity">
            <parameter
                android:name="itemList.name"
                android:key="itemName"/>
